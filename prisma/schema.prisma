generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               Int       @id @default(autoincrement())
  nombre           String    @db.VarChar(80)
  apellidoPaterno  String    @map("apellido_paterno") @db.VarChar(60)
  apellidoMaterno  String?   @map("apellido_materno") @db.VarChar(60)
  correo           String    @unique @db.VarChar(120)
  telefono         String?   @db.VarChar(15)
  contrasenaHash   String    @map("contrasena_hash") @db.Text
  rol              String    @db.VarChar(20) // 'admin', 'instructor', 'alumno'
  activo           Boolean   @default(true)
  creadoEn         DateTime  @default(now()) @map("creado_en")

  instructor       Instructor?
  inscripciones    Inscripcion[]
  notificaciones   Notificacion[]

  @@map("usuarios")
}

model Instructor {
  id             Int       @id @default(autoincrement())
  usuarioId      Int       @unique @map("id_usuario")
  especialidad   String?   @db.VarChar(100)

  usuario        Usuario   @relation(fields: [usuarioId], references: [id])
  disponibilidad DisponibilidadInstructor[]
  clases         Clase[]

  @@map("instructores")
}

model DisponibilidadInstructor {
  id           Int        @id @default(autoincrement())
  instructorId Int        @map("id_instructor")
  diaSemana    String     @map("dia_semana") @db.VarChar(15) // 'lunes', etc.
  horaInicio   DateTime   @map("hora_inicio") @db.Time
  horaFin      DateTime   @map("hora_fin") @db.Time
  activo       Boolean    @default(true)

  instructor   Instructor @relation(fields: [instructorId], references: [id])

  @@map("disponibilidad_instructores")
}

model Automovil {
  id      Int     @id @default(autoincrement())
  modelo  String  @db.VarChar(80)
  placa   String  @unique @db.VarChar(20)
  estado  String  @db.VarChar(20) // 'disponible', 'en_uso', 'mantenimiento'

  clases  Clase[]

  @@map("automoviles")
}

model Curso {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(120)
  descripcion String?  @db.Text
  duracion    Int      // Número de clases
  activo      Boolean  @default(true)

  inscripciones Inscripcion[]

  @@map("cursos")
}

model Inscripcion {
  id          Int      @id @default(autoincrement())
  alumnoId    Int      @map("id_alumno")
  cursoId     Int      @map("id_curso")
  fechaInicio DateTime @map("fecha_inicio") @db.Date
  estado      String   @db.VarChar(20) // 'activo', 'completado', 'abandonado'
  creadoEn    DateTime @default(now()) @map("creado_en")

  alumno      Usuario  @relation(fields: [alumnoId], references: [id])
  curso       Curso    @relation(fields: [cursoId], references: [id])
  clases      Clase[]

  @@map("inscripciones")
}

model Clase {
  id             Int       @id @default(autoincrement())
  inscripcionId  Int       @map("id_inscripcion")
  instructorId   Int       @map("id_instructor")
  automovilId    Int?      @map("id_automovil") // Ahora es opcional
  fecha          DateTime  @db.Date
  horaInicio     DateTime  @map("hora_inicio") @db.Time
  horaFin        DateTime  @map("hora_fin") @db.Time
  estado         String    @db.VarChar(20) // 'programada', 'completada', 'cancelada'

  inscripcion    Inscripcion @relation(fields: [inscripcionId], references: [id])
  instructor     Instructor  @relation(fields: [instructorId], references: [id])
  automovil      Automovil?  @relation(fields: [automovilId], references: [id])
  bitacora       BitacoraClase[]

  @@map("clases")
}

model BitacoraClase {
  id             Int      @id @default(autoincrement())
  claseId        Int      @map("id_clase")
  estadoAnterior String   @map("estado_anterior") @db.VarChar(20)
  estadoNuevo    String   @map("estado_nuevo") @db.VarChar(20)
  motivo         String?  @db.Text
  fechaCambio    DateTime @default(now()) @map("fecha_cambio")

  clase          Clase    @relation(fields: [claseId], references: [id])

  @@map("bitacora_clases")
}

model Notificacion {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("id_usuario")
  titulo     String   @db.VarChar(120)
  mensaje    String   @db.Text
  leida      Boolean  @default(false)
  creadaEn   DateTime @default(now()) @map("creada_en")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("notificaciones")
}